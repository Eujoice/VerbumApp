<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Acervo"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/viewPagerFeatured"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp">

            <View
                android:layout_width="wrap_content"
                android:layout_height="148dp"
                android:background="@drawable/bannerpercy" />

        </FrameLayout>


        <LinearLayout
            android:id="@+id/dotsIndicator"
            android:layout_width="12dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">


        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Populares"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#6C9467"/>

            <TextView
                android:id="@+id/tvVerMaisPopulares"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver mais"
                android:textSize="13sp"
                android:textColor="#2E7D32"
                android:paddingEnd="4dp"/>

        </LinearLayout>


        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Book Card 1 - Crime e Castigo -->
                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="155dp">

                        <ImageView
                            android:id="@+id/imgBook1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="Crime e Castigo"
                            android:background="@drawable/crime" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Crime e Castigo"
                        android:textSize="12sp"
                        android:textColor="#6C9467"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Fiódor Dostoiévski"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                </LinearLayout>

                <!-- Book Card 2 - Os sete maridos -->
                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="155dp">

                        <ImageView
                            android:id="@+id/imgBook2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/setemaridos"
                            android:contentDescription="Os sete maridos"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Os sete maridos..."
                        android:textSize="12sp"
                        android:textColor="#6C9467"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Taylor Jenkins Reid"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Book Card 3 - Dom Quixote -->
                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="155dp">

                        <ImageView
                            android:id="@+id/imgBook3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/domquixote"
                            android:contentDescription="Dom Quixote"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dom Quixote"
                        android:textSize="12sp"
                        android:textColor="#6C9467"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Miguel de Cervantes"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ficção"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#6C9467"/>

            <TextView
                android:id="@+id/tvVerMaisFiccao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver mais"
                android:textSize="13sp"
                android:textColor="#2E7D32"
                android:paddingEnd="4dp"/>


        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="155dp">

                        <ImageView
                            android:id="@+id/imgBook4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/biblioteca"
                            android:contentDescription="A biblioteca da meia-noite"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A biblioteca da..."
                        android:textSize="12sp"
                        android:textColor="#6C9467"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Matt Haig"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="155dp">

                        <ImageView
                            android:id="@+id/imgBook5"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/hobiit"
                            android:contentDescription="O Hobbit"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="O Hobbit"
                        android:textSize="12sp"
                        android:textColor="#6C9467"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="J.R.R Tolkien"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <FrameLayout
                        android:layout_width="110dp"
                        android:layout_height="155dp">

                        <ImageView
                            android:id="@+id/imgBook6"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/horadaestrela"
                            android:contentDescription="A Hora da Estrela"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="A Hora da Estrela"
                        android:textSize="12sp"
                        android:textColor="#6C9467"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Clarice Lispector"
                        android:textSize="11sp"
                        android:textColor="#666666"
                        android:layout_marginTop="2dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>
</ScrollView>